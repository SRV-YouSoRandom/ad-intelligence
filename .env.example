# Meta
META_ACCESS_TOKEN=your_long_lived_token_here
META_API_VERSION=v23.0

# OpenRouter
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CLASSIFICATION_MODEL=qwen/qwen3-vl-30b-a3b-thinking
INSIGHT_MODEL=qwen/qwen3-vl-235b-a22b-thinking

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://adint:adint@postgres:5432/adint

# Valkey
VALKEY_URL=redis://valkey:6379/0

# App
APP_ENV=production
LOG_LEVEL=INFO
MEDIA_STORAGE_PATH=/app/media_storage
MAX_CONCURRENT_DOWNLOADS=5
